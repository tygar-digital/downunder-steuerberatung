---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getLocaleFromPath } from '../lib/i18n';

const locale = getLocaleFromPath(Astro.url.pathname);

const notFound = {
  de: {
    title: 'Seite nicht gefunden',
    description: 'Die gesuchte Seite existiert nicht.',
    code: '404',
    headline: 'Seite nicht gefunden',
    text: 'Die Seite die du suchst existiert leider nicht oder wurde verschoben.',
    buttonText: 'Zurück zur Startseite',
    buttonHref: '/',
  },
  en: {
    title: 'Page Not Found',
    description: 'The page you are looking for does not exist.',
    code: '404',
    headline: 'Page Not Found',
    text: 'The page you are looking for does not exist or has been moved.',
    buttonText: 'Back to Homepage',
    buttonHref: '/en/',
  },
};

const page = notFound[locale];
---

<BaseLayout title={page.title} description={page.description}>
  <section class="py-20 md:py-32" style="background-color: var(--color-background);">
    <div class="mx-auto max-w-7xl px-5 sm:px-8 text-center">
      <div class="max-w-lg mx-auto">
        <p
          class="text-8xl md:text-9xl font-extrabold mb-6 leading-none"
          style="color: var(--color-primary-fixed); font-family: var(--font-display);"
        >
          {page.code}
        </p>
        <h1 class="text-2xl md:text-3xl mb-4" style="font-family: var(--font-display);">
          {page.headline}
        </h1>
        <p class="text-lg leading-relaxed mb-10" style="color: var(--color-on-surface-variant);">
          {page.text}
        </p>
        <a
          href={page.buttonHref}
          class="inline-flex items-center gap-2 px-7 py-3.5 rounded-[var(--radius-xl)] text-base font-semibold transition-all duration-200 hover:shadow-[var(--shadow-float)]"
          style="background: var(--color-secondary-container); color: var(--color-on-secondary-container);"
        >
          {page.buttonText}
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M3.33 8H12.67M12.67 8L8.67 4M12.67 8L8.67 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
