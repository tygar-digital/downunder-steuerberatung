---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Impressum">
  <!-- Page Hero -->
  <section class="py-16 md:py-20" style="background: var(--gradient-hero);">
    <div class="mx-auto max-w-7xl px-5 sm:px-8">
      <p class="text-sm font-medium mb-3 uppercase tracking-wider" style="color: var(--color-primary-fixed-dim); font-family: var(--font-display);">
        Rechtliches
      </p>
      <h1 class="text-white">Impressum</h1>
    </div>
  </section>

  <!-- Content -->
  <section class="py-16 md:py-24" style="background-color: var(--color-background);">
    <div class="mx-auto max-w-3xl px-5 sm:px-8">
      <div
        class="p-8 md:p-12 rounded-[var(--radius-lg)]"
        style="background-color: var(--color-surface-lowest); box-shadow: var(--shadow-ambient);"
      >
        <h2 class="text-xl mb-6" style="font-family: var(--font-display);">Angaben gemäß § 5 TMG</h2>

        <div class="space-y-8 text-[var(--color-on-surface-variant)]">
          <div>
            <h3 class="text-base font-semibold mb-2" style="color: var(--color-on-surface); font-family: var(--font-display);">Firmenname</h3>
            <p>DownUnder Steuerberatung</p>
            <p class="text-sm mt-1 italic" style="color: var(--color-outline);">[Vollständiger Firmenname hier eintragen]</p>
          </div>

          <div>
            <h3 class="text-base font-semibold mb-2" style="color: var(--color-on-surface); font-family: var(--font-display);">Adresse</h3>
            <p>[Straße und Hausnummer]</p>
            <p>[PLZ und Ort]</p>
            <p>Deutschland</p>
          </div>

          <div>
            <h3 class="text-base font-semibold mb-2" style="color: var(--color-on-surface); font-family: var(--font-display);">Kontakt</h3>
            <p>E-Mail: hello@downunder-steuerberatung.com</p>
            <p>Telefon: [Telefonnummer]</p>
          </div>

          <div>
            <h3 class="text-base font-semibold mb-2" style="color: var(--color-on-surface); font-family: var(--font-display);">Vertreten durch</h3>
            <p>[Name des Geschäftsführers / Inhabers]</p>
          </div>

          <div>
            <h3 class="text-base font-semibold mb-2" style="color: var(--color-on-surface); font-family: var(--font-display);">Registereintrag</h3>
            <p>Registergericht: [Amtsgericht]</p>
            <p>Registernummer: [HRB-Nummer]</p>
          </div>

          <div>
            <h3 class="text-base font-semibold mb-2" style="color: var(--color-on-surface); font-family: var(--font-display);">Umsatzsteuer-ID</h3>
            <p>Umsatzsteuer-Identifikationsnummer gemäß §27a UStG:</p>
            <p>[USt-IdNr.]</p>
          </div>

          <div>
            <h3 class="text-base font-semibold mb-2" style="color: var(--color-on-surface); font-family: var(--font-display);">Berufsbezeichnung & Aufsichtsbehörde</h3>
            <p>Berufsbezeichnung: Steuerberater</p>
            <p>Zuständige Kammer: [Steuerberaterkammer]</p>
            <p>Verliehen in: Deutschland</p>
          </div>

          <div>
            <h3 class="text-base font-semibold mb-2" style="color: var(--color-on-surface); font-family: var(--font-display);">Streitschlichtung</h3>
            <p class="text-sm leading-relaxed">
              Die Europäische Kommission stellt eine Plattform zur Online-Streitbeilegung (OS) bereit.
              Wir sind nicht bereit oder verpflichtet, an Streitbeilegungsverfahren vor einer Verbraucherschlichtungsstelle teilzunehmen.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
