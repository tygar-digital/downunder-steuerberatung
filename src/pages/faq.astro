---
import BaseLayout from '../layouts/BaseLayout.astro';

const categories = [
  { id: 'whv', label: 'Work & Holiday' },
  { id: 'studenten', label: 'Studenten' },
  { id: 'expats', label: 'Expats & Auswanderer' },
];

const faqs = {
  whv: [
    {
      question: 'Wann muss ich in Australien eine Steuererklärung abgeben?',
      answer: 'Das australische Steuerjahr läuft vom 1. Juli bis 30. Juni. Die reguläre Abgabefrist ist der 31. Oktober. Wenn du einen registrierten Tax Agent nutzt, gelten verlängerte Fristen.',
    },
    {
      question: 'Wie hoch ist meine Rückerstattung?',
      answer: 'Working Holiday Maker erhalten durchschnittlich $2.500+ zurück. Die genaue Höhe hängt von Einkommen, Abzügen und Aufenthaltsdauer ab.',
    },
    {
      question: 'Brauche ich eine TFN?',
      answer: 'Ja, die Tax File Number ist essentiell. Ohne TFN wird der Höchststeuersatz von 45% + Medicare Levy abgezogen.',
    },
    {
      question: 'Was ist die Medicare Levy?',
      answer: 'Die Medicare Levy beträgt 2% des Einkommens. Viele Deutsche mit WHV sind davon befreit, da sie keinen Zugang zum Medicare-System haben.',
    },
    {
      question: 'Kann ich meine Superannuation zurückbekommen?',
      answer: 'Ja, über einen DASP-Antrag (Departing Australia Superannuation Payment) kannst du dir deine Beiträge auszahlen lassen, sobald du Australien verlässt und dein Visum abgelaufen ist.',
    },
  ],
  studenten: [
    {
      question: 'Muss ich als Student Steuern zahlen?',
      answer: 'Wenn du in Australien arbeitest, ja. Auch mit Studentenvisum bist du steuerpflichtig auf australisches Einkommen.',
    },
    {
      question: 'Kann ich Studiengebühren absetzen?',
      answer: 'Studiengebühren sind in Australien nur bedingt absetzbar. Wir prüfen deine individuelle Situation und finden mögliche Abzüge.',
    },
    {
      question: 'Was passiert mit meinem deutschen Steuerresidenz-Status?',
      answer: 'Das hängt von der Dauer deines Aufenthalts ab. Ab 183 Tagen kann sich deine steuerliche Ansässigkeit ändern. Wir beraten dich dazu.',
    },
  ],
  expats: [
    {
      question: 'Muss ich in Deutschland weiterhin Steuern zahlen?',
      answer: 'Das kommt auf deine steuerliche Ansässigkeit an. Das Doppelbesteuerungsabkommen zwischen Deutschland und Australien regelt, wo welches Einkommen versteuert wird.',
    },
    {
      question: 'Was ist das Doppelbesteuerungsabkommen?',
      answer: 'Das DBA zwischen DE und AU verhindert, dass du auf dasselbe Einkommen in beiden Ländern Steuern zahlst. Wir analysieren deine Situation und nutzen das DBA optimal.',
    },
    {
      question: 'Wie funktioniert die steuerliche Ansässigkeit?',
      answer: 'Die steuerliche Residency wird nach dem \'Resides Test\' bestimmt. Faktoren: Dauer des Aufenthalts, Wohnsitz, wirtschaftliche und persönliche Bindungen.',
    },
    {
      question: 'Kann ich in Australien Immobilien besitzen?',
      answer: 'Ja, als Ausländer gibt es bestimmte Regeln (FIRB-Genehmigung). Mieteinnahmen und Veräußerungsgewinne sind steuerpflichtig. Wir beraten dich zu den steuerlichen Implikationen.',
    },
  ],
};

const resources = [
  {
    title: 'Tax Guide für WHV',
    description: 'Unser umfassender Leitfaden für Working Holiday Maker.',
  },
  {
    title: 'Steuer-Checkliste',
    description: 'Alle Dokumente die du für deine Steuererklärung brauchst.',
  },
  {
    title: 'DBA-Übersicht DE/AU',
    description: 'Das Wichtigste zum Doppelbesteuerungsabkommen.',
  },
];
---

<BaseLayout
  title="FAQ & Wissen"
  description="Häufige Fragen zu Steuern in Australien für Deutsche — verständlich beantwortet. Work & Holiday, Studenten, Expats."
>

  <!-- Hero -->
  <section class="relative py-20 md:py-28 overflow-hidden" style="background: var(--gradient-hero);">
    <div class="absolute inset-0 opacity-[0.04]" style="background-image: radial-gradient(circle at 1px 1px, white 1px, transparent 0); background-size: 40px 40px;"></div>
    <div class="relative mx-auto max-w-7xl px-5 sm:px-8">
      <p
        class="text-sm font-semibold uppercase tracking-widest mb-4"
        style="color: var(--color-secondary-container); font-family: var(--font-display);"
      >
        FAQ & Wissen
      </p>
      <h1 class="text-white max-w-3xl">
        Häufige Fragen — verständlich beantwortet
      </h1>
      <p class="mt-5 text-lg max-w-2xl leading-relaxed" style="color: var(--color-primary-fixed-dim);">
        Alles was du über Steuern in Australien wissen musst.
      </p>
    </div>
  </section>

  <!-- Category Tabs + FAQ Accordions -->
  <section class="py-20 md:py-28" style="background-color: var(--color-background);">
    <div class="mx-auto max-w-3xl px-5 sm:px-8">

      <!-- Tabs -->
      <div class="flex flex-wrap gap-2 mb-12" role="tablist">
        {categories.map((cat, index) => (
          <button
            role="tab"
            aria-selected={index === 0 ? 'true' : 'false'}
            aria-controls={`panel-${cat.id}`}
            data-tab={cat.id}
            class:list={[
              'faq-tab px-5 py-2.5 rounded-[var(--radius-full)] text-sm font-semibold transition-all duration-200 cursor-pointer',
              index === 0
                ? 'active'
                : ''
            ]}
            style={`font-family: var(--font-display);`}
          >
            {cat.label}
          </button>
        ))}
      </div>

      <!-- FAQ Panels -->
      {Object.entries(faqs).map(([categoryId, questions], catIndex) => (
        <div
          id={`panel-${categoryId}`}
          role="tabpanel"
          class:list={['faq-panel', catIndex !== 0 && 'hidden']}
          data-panel={categoryId}
        >
          <div class="space-y-3">
            {questions.map((faq, index) => (
              <div
                class="faq-item rounded-[var(--radius-lg)] overflow-hidden transition-colors duration-200"
                style="background-color: var(--color-surface-lowest);"
              >
                <button
                  class="faq-trigger w-full flex items-center justify-between gap-4 p-6 text-left cursor-pointer"
                  aria-expanded="false"
                >
                  <span class="text-base font-semibold pr-4" style="font-family: var(--font-display); color: var(--color-on-surface);">
                    {faq.question}
                  </span>
                  <span class="faq-icon shrink-0 w-6 h-6 flex items-center justify-center transition-transform duration-300">
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <path d="M4 6L8 10L12 6" stroke="var(--color-on-surface-variant)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </span>
                </button>
                <div class="faq-content" style="max-height: 0; overflow: hidden; transition: max-height 0.3s ease;">
                  <div class="px-6 pb-6 -mt-1">
                    <p class="leading-relaxed" style="color: var(--color-on-surface-variant);">
                      {faq.answer}
                    </p>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Resources -->
  <section class="py-20 md:py-28" style="background-color: var(--color-surface-low);">
    <div class="mx-auto max-w-7xl px-5 sm:px-8">
      <h2 class="mb-12">Nützliche Ressourcen</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {resources.map((resource) => (
          <div
            class="group p-8 rounded-[var(--radius-lg)] flex flex-col transition-shadow duration-200 hover:shadow-[var(--shadow-float)] cursor-pointer"
            style="background-color: var(--color-surface-lowest);"
          >
            <!-- Download Icon -->
            <div
              class="w-12 h-12 rounded-[var(--radius-md)] flex items-center justify-center mb-5 transition-colors duration-200"
              style="background-color: var(--color-primary-fixed);"
            >
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M10 3V13M10 13L6 9M10 13L14 9" stroke="var(--color-primary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M3 15V16C3 16.55 3.45 17 4 17H16C16.55 17 17 16.55 17 16V15" stroke="var(--color-primary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <h3 class="text-lg mb-2" style="font-family: var(--font-display);">{resource.title}</h3>
            <p class="leading-relaxed" style="color: var(--color-on-surface-variant);">
              {resource.description}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 md:py-28" style="background: var(--gradient-hero);">
    <div class="mx-auto max-w-7xl px-5 sm:px-8 text-center">
      <h2 class="text-white mb-4">Noch Fragen?</h2>
      <p class="text-lg max-w-xl mx-auto mb-10 leading-relaxed" style="color: var(--color-primary-fixed-dim);">
        Unser Team berät dich gerne persönlich.
      </p>
      <a
        href="/kontakt"
        class="inline-flex items-center gap-2 px-8 py-4 rounded-[var(--radius-xl)] text-base font-semibold transition-all duration-200 hover:shadow-[var(--shadow-elevated)]"
        style="background: var(--color-secondary-container); color: var(--color-on-secondary-container);"
      >
        Jetzt Kontakt aufnehmen
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M3.33 8H12.67M12.67 8L8.67 4M12.67 8L8.67 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
  </section>

</BaseLayout>

<style>
  .faq-tab {
    background-color: var(--color-surface-low);
    color: var(--color-on-surface-variant);
  }
  .faq-tab:hover {
    background-color: var(--color-surface-high);
  }
  .faq-tab.active {
    background-color: var(--color-primary);
    color: var(--color-on-primary);
  }
</style>

<script>
  // Tab switching
  const tabs = document.querySelectorAll<HTMLButtonElement>('.faq-tab');
  const panels = document.querySelectorAll<HTMLDivElement>('.faq-panel');

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const targetId = tab.getAttribute('data-tab');

      // Update tabs
      tabs.forEach((t) => {
        t.classList.remove('active');
        t.setAttribute('aria-selected', 'false');
      });
      tab.classList.add('active');
      tab.setAttribute('aria-selected', 'true');

      // Update panels
      panels.forEach((panel) => {
        if (panel.getAttribute('data-panel') === targetId) {
          panel.classList.remove('hidden');
        } else {
          panel.classList.add('hidden');
        }
      });
    });
  });

  // Accordion toggle
  const triggers = document.querySelectorAll<HTMLButtonElement>('.faq-trigger');

  triggers.forEach((trigger) => {
    trigger.addEventListener('click', () => {
      const item = trigger.closest('.faq-item')!;
      const content = item.querySelector<HTMLDivElement>('.faq-content')!;
      const icon = trigger.querySelector<HTMLSpanElement>('.faq-icon')!;
      const isOpen = trigger.getAttribute('aria-expanded') === 'true';

      if (isOpen) {
        content.style.maxHeight = '0';
        trigger.setAttribute('aria-expanded', 'false');
        icon.style.transform = 'rotate(0deg)';
      } else {
        content.style.maxHeight = content.scrollHeight + 'px';
        trigger.setAttribute('aria-expanded', 'true');
        icon.style.transform = 'rotate(180deg)';
      }
    });
  });
</script>
