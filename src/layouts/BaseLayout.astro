---
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import { getLocaleFromPath, getAlternatePath } from '../lib/i18n';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  schema?: object;
}

const locale = getLocaleFromPath(Astro.url.pathname);
const alternatePath = getAlternatePath(Astro.url.pathname);

const defaultDescriptions = {
  de: 'Steuerberatung für Deutsche in Australien — auf Deutsch, ohne Stress. Tax Returns, Beratung und mehr.',
  en: 'Tax consulting for Germans in Australia — in German, stress-free. Tax returns, advice and more.',
};

const skipLabels = { de: 'Zum Inhalt springen', en: 'Skip to content' };

const {
  title,
  description = defaultDescriptions[locale],
  ogImage = '/og-image.jpg',
  schema
} = Astro.props;

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  "name": "DownUnder Steuerberatung",
  "description": "Tax consulting for Germans in Australia — Tax Returns, Superannuation, TFN/ABN and individual advice.",
  "url": "https://downunder-steuerberatung.com",
  "email": "hello@downunder-steuerberatung.com",
  "knowsLanguage": ["de", "en"],
  "areaServed": "AU",
  "serviceType": "Tax Consulting"
};

const canonicalURL = Astro.site ? new URL(Astro.url.pathname, Astro.site) : Astro.url;
const siteUrl = Astro.site?.origin || 'https://downunder-steuerberatung.com';
---

<!DOCTYPE html>
<html lang={locale}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />

  <!-- Preload Fonts (lokal gehostet) -->
  <link rel="preload" href="/fonts/manrope-latin.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/fonts/inter-latin.woff2" as="font" type="font/woff2" crossorigin />

  <!-- SEO -->
  <link rel="canonical" href={canonicalURL} />
  <link rel="alternate" hreflang="de" href={`${siteUrl}${locale === 'de' ? Astro.url.pathname : alternatePath}`} />
  <link rel="alternate" hreflang="en" href={`${siteUrl}${locale === 'en' ? Astro.url.pathname : alternatePath}`} />
  <link rel="alternate" hreflang="x-default" href={`${siteUrl}${locale === 'de' ? Astro.url.pathname : alternatePath}`} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:image" content={ogImage} />
  <meta name="twitter:card" content="summary_large_image" />

  <!-- Favicon -->
  <link rel="icon" href="/favicon.ico" sizes="any" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

  <title>{title} | DownUnder Steuerberatung</title>

  <!-- Schema.org -->
  <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />
  {schema && <script type="application/ld+json" set:html={JSON.stringify(schema)} />}
</head>
<body class="min-h-screen flex flex-col">
  <a href="#main-content" class="skip-to-content">{skipLabels[locale]}</a>
  <Navigation />
  <main id="main-content" class="flex-1" tabindex="-1">
    <slot />
  </main>
  <Footer />
</body>
</html>
