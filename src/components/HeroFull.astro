---
interface Props {
  paletteName: string;
}

const { paletteName } = Astro.props;
---

<div class={paletteName}>
  <div class="min-h-screen flex flex-col" style="background: var(--color-bg)">

    <!-- Decorative Elements -->
    <div
      class="absolute top-[-10%] right-[-5%] w-[400px] h-[400px] rounded-full blur-3xl pointer-events-none"
      style="background: var(--color-accent-glow)"
    ></div>

    <!-- Navigation -->
    <nav class="relative z-10 w-full">
      <div class="max-w-6xl mx-auto px-5 py-5 flex items-center justify-between">
        <div class="flex items-center gap-2">
          <span class="text-xl font-bold tracking-tight" style="font-family: 'Space Grotesk'; color: var(--color-text)">
            DownUnder
          </span>
          <span class="text-xl font-light" style="font-family: 'Space Grotesk'; color: var(--color-text-muted)">
            Steuerberatung
          </span>
        </div>
        <button
          class="px-5 py-2.5 rounded-lg text-sm font-semibold transition-all"
          style={`background: var(--color-cta); color: var(--color-cta-text)`}
        >
          Kontakt
        </button>
      </div>
    </nav>

    <!-- Main Hero -->
    <div class="relative z-10 flex-1 flex items-center">
      <div class="max-w-6xl mx-auto px-5 py-12 md:py-16">
        <div class="max-w-2xl">

          <!-- Overline -->
          <p
            class="text-xs sm:text-sm font-semibold tracking-[0.15em] uppercase mb-5"
            style="color: var(--color-accent)"
          >
            Steuerberatung für Deutsche in Australien
          </p>

          <!-- Headline -->
          <h1
            class="text-[clamp(2rem,5vw,3.75rem)] leading-[1.1] font-bold mb-6 tracking-tight"
            style="color: var(--color-text)"
          >
            Deine Steuererklärung in Australien — <br class="hidden md:block"/>
            <span style="color: var(--color-accent)">auf Deutsch,</span> ohne Stress.
          </h1>

          <!-- Subline -->
          <p
            class="text-base sm:text-lg leading-relaxed mb-10 max-w-xl"
            style="color: var(--color-text-muted)"
          >
            Wir kümmern uns um deinen Australian Tax Return — du genießt das Land. Persönlich, verständlich und komplett online.
          </p>

          <!-- CTA Group -->
          <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4 mb-14">
            <button
              class="px-8 py-4 rounded-xl text-base font-semibold shadow-lg"
              style={`background: var(--color-cta); color: var(--color-cta-text)`}
            >
              Jetzt Beratung anfragen
            </button>
            <a
              href="#"
              class="text-sm font-semibold flex items-center gap-2"
              style="color: var(--color-accent)"
            >
              So funktioniert's
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M3 8h10M9 4l4 4-4 4"/>
              </svg>
            </a>
          </div>

          <!-- Trust Badges -->
          <div class="flex flex-wrap items-center gap-x-6 gap-y-3">
            <div class="flex items-center gap-2">
              <svg class="w-4 h-4" style="color: var(--color-accent)" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
              </svg>
              <span class="text-xs font-medium" style="color: var(--color-text-muted)">200+ Tax Returns</span>
            </div>
            <div class="w-px h-4" style="background: var(--color-divider)"></div>
            <div class="flex items-center gap-2">
              <svg class="w-4 h-4" style="color: var(--color-accent)" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
              </svg>
              <span class="text-xs font-medium" style="color: var(--color-text-muted)">Auf Deutsch</span>
            </div>
            <div class="w-px h-4" style="background: var(--color-divider)"></div>
            <div class="flex items-center gap-2">
              <svg class="w-4 h-4" style="color: var(--color-accent)" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
              <span class="text-xs font-medium" style="color: var(--color-text-muted)">100% Online</span>
            </div>
          </div>

        </div>
      </div>
    </div>
  </div>
</div>
