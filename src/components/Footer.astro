---
const currentYear = new Date().getFullYear();

const footerLinks = {
  services: [
    { href: '/leistungen', label: 'Tax Returns' },
    { href: '/leistungen', label: 'Superannuation' },
    { href: '/leistungen', label: 'TFN & ABN' },
    { href: '/leistungen', label: 'Steuerberatung' },
  ],
  company: [
    { href: '/ueber-uns', label: 'Über uns' },
    { href: '/faq', label: 'FAQ & Wissen' },
    { href: '/kontakt', label: 'Kontakt' },
  ],
  legal: [
    { href: '/impressum', label: 'Impressum' },
    { href: '/datenschutz', label: 'Datenschutz' },
  ],
};
---

<footer class="mt-auto" style="background-color: var(--color-primary);">
  <div class="mx-auto max-w-7xl px-5 sm:px-8 py-16 md:py-20">
    <!-- Top Section -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 lg:gap-8">
      <!-- Brand -->
      <div class="lg:col-span-1">
        <a href="/" class="flex items-center gap-2 mb-5">
          <img src="/logo.svg" alt="DownUnder Logo" class="h-10 w-auto" />
          <span class="font-bold text-lg text-white" style="font-family: var(--font-display);">
            DownUnder
          </span>
        </a>
        <p class="text-sm leading-relaxed" style="color: var(--color-primary-fixed-dim);">
          Steuerberatung für Deutsche in Australien. Auf Deutsch, ohne Stress — von Expats für Expats.
        </p>
      </div>

      <!-- Services -->
      <div>
        <h4 class="text-sm font-semibold text-white mb-4 uppercase tracking-wider" style="font-family: var(--font-display);">
          Leistungen
        </h4>
        <ul class="space-y-3">
          {footerLinks.services.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-sm transition-colors duration-200 hover:text-white"
                style="color: var(--color-primary-fixed-dim);"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h4 class="text-sm font-semibold text-white mb-4 uppercase tracking-wider" style="font-family: var(--font-display);">
          Unternehmen
        </h4>
        <ul class="space-y-3">
          {footerLinks.company.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-sm transition-colors duration-200 hover:text-white"
                style="color: var(--color-primary-fixed-dim);"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Offices -->
      <div>
        <h4 class="text-sm font-semibold text-white mb-4 uppercase tracking-wider" style="font-family: var(--font-display);">
          Standorte
        </h4>
        <div class="space-y-4">
          <div>
            <p class="text-sm font-medium text-white">Sydney</p>
            <p class="text-sm" style="color: var(--color-primary-fixed-dim);">
              120 Pitt Street<br />Sydney, NSW 2000
            </p>
          </div>
          <div>
            <p class="text-sm font-medium text-white">Berlin</p>
            <p class="text-sm" style="color: var(--color-primary-fixed-dim);">
              Friedrichstraße 100<br />10117 Berlin
            </p>
          </div>
        </div>
      </div>
    </div>

    <!-- Divider -->
    <div class="mt-14 pt-8" style="border-top: 1px solid rgba(167, 200, 255, 0.15);">
      <div class="flex flex-col sm:flex-row justify-between items-center gap-4">
        <p class="text-xs" style="color: var(--color-primary-fixed-dim);">
          &copy; {currentYear} DownUnder Steuerberatung. Alle Rechte vorbehalten.
        </p>
        <div class="flex items-center gap-6">
          {footerLinks.legal.map((link) => (
            <a
              href={link.href}
              class="text-xs transition-colors duration-200 hover:text-white"
              style="color: var(--color-primary-fixed-dim);"
            >
              {link.label}
            </a>
          ))}
        </div>
      </div>
    </div>
  </div>
</footer>
