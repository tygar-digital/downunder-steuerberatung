---
import BaseLayout from '../../layouts/BaseLayout.astro';

interface Props {
  content: any;
  locale: string;
}

const { content, locale } = Astro.props;
const page = content.datenschutz;
---

<BaseLayout title={page.hero.headline}>
  <!-- Page Hero -->
  <section class="py-16 md:py-20" style="background: var(--gradient-hero);">
    <div class="mx-auto max-w-7xl px-5 sm:px-8">
      <p class="text-sm font-medium mb-3 uppercase tracking-wider" style="color: var(--color-primary-fixed-dim); font-family: var(--font-display);">
        {page.hero.badge}
      </p>
      <h1 class="text-white">{page.hero.headline}</h1>
    </div>
  </section>

  <!-- Content -->
  <section class="py-16 md:py-24" style="background-color: var(--color-background);">
    <div class="mx-auto max-w-3xl px-5 sm:px-8">
      <div
        class="p-8 md:p-12 rounded-[var(--radius-lg)]"
        style="background-color: var(--color-surface-lowest); box-shadow: var(--shadow-ambient);"
      >
        <div class="space-y-10 text-[var(--color-on-surface-variant)]">

          {page.sections.map((section: any) => (
            <div>
              <h2 class="text-xl mb-4" style="font-family: var(--font-display); color: var(--color-on-surface);">
                {section.title}
              </h2>

              {section.content.map((block: any) => (
                <Fragment>
                  {block.subtitle && (
                    <h3 class="text-base font-semibold mb-2 mt-6" style="color: var(--color-on-surface); font-family: var(--font-display);">
                      {block.subtitle}
                    </h3>
                  )}

                  {block.text && (
                    <p class="text-sm leading-relaxed">
                      {block.text}
                    </p>
                  )}

                  {block.address && (
                    <div class="mt-3 p-4 rounded-[var(--radius-md)]" style="background-color: var(--color-surface-low);">
                      {block.address.map((line: string) => (
                        <p class="text-sm">{line}</p>
                      ))}
                    </div>
                  )}

                  {block.list && (
                    <ul class="text-sm leading-relaxed space-y-1 pl-4">
                      {block.list.map((item: string) => (
                        <li>&bull; {item}</li>
                      ))}
                    </ul>
                  )}
                </Fragment>
              ))}
            </div>
          ))}

          {page.footer && (
            <div class="pt-4" style="border-top: 1px solid rgba(195, 198, 209, 0.15);">
              <p class="text-xs" style="color: var(--color-outline);">
                {page.footer}
              </p>
            </div>
          )}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
