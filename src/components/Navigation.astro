---
import { getLocaleFromPath, getContent } from '../lib/i18n';
import LanguageSwitcher from './LanguageSwitcher.astro';

const locale = getLocaleFromPath(Astro.url.pathname);
const content = getContent(locale);
const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
const { links: navLinks, logoAlt, brandName, ctaText, ctaHref, mobileMenuLabel } = content.nav;
const homeHref = locale === 'en' ? '/en/' : '/';
---

<header
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
  id="main-nav"
>
  <div class="mx-auto max-w-7xl px-5 sm:px-8">
    <nav class="flex items-center justify-between h-20">
      <!-- Logo -->
      <a href={homeHref} class="flex items-center gap-2 group">
        <img src="/logo.svg" alt={logoAlt} class="h-10 w-auto" />
        <span class="font-bold text-lg" style="font-family: var(--font-display); color: var(--color-on-surface);">
          {brandName}
        </span>
      </a>

      <!-- Desktop Links -->
      <div class="hidden md:flex items-center gap-8">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class:list={[
              'text-sm font-medium transition-colors duration-200',
              (currentPath === link.href.replace(/\/$/, '') || currentPath === link.href)
                ? 'text-[var(--color-primary)]'
                : 'text-[var(--color-on-surface-variant)] hover:text-[var(--color-primary)]'
            ]}
          >
            {link.label}
          </a>
        ))}
      </div>

      <!-- Language Switch + CTA + Mobile Toggle -->
      <div class="flex items-center gap-4">
        <div class="hidden sm:block">
          <LanguageSwitcher />
        </div>
        <a
          href={ctaHref}
          class="hidden sm:inline-flex items-center gap-2 px-5 py-2.5 rounded-[var(--radius-xl)] text-sm font-semibold transition-all duration-200 hover:shadow-[var(--shadow-float)]"
          style="background: var(--color-secondary-container); color: var(--color-on-secondary-container);"
        >
          {ctaText}
        </a>

        <!-- Mobile Menu Button -->
        <button
          id="mobile-toggle"
          class="md:hidden flex items-center justify-center w-11 h-11"
          aria-label={mobileMenuLabel}
          aria-expanded="false"
        >
          <svg id="icon-menu" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" style="color: var(--color-on-surface);">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <svg id="icon-close" class="w-6 h-6 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" style="color: var(--color-on-surface);">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 6l12 12M6 18L18 6" />
          </svg>
        </button>
      </div>
    </nav>
  </div>

  <!-- Mobile Menu -->
  <div
    id="mobile-menu"
    class="md:hidden overflow-hidden transition-all duration-300 max-h-0 opacity-0"
  >
    <div class="px-5 pb-6 pt-2 flex flex-col gap-1">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class:list={[
            'block px-4 py-3 rounded-[var(--radius-md)] text-base font-medium transition-colors duration-200',
            (currentPath === link.href.replace(/\/$/, '') || currentPath === link.href)
              ? 'text-[var(--color-primary)] bg-[var(--color-primary-fixed)]'
              : 'text-[var(--color-on-surface-variant)] hover:bg-[var(--color-surface-low)]'
          ]}
        >
          {link.label}
        </a>
      ))}
      <div class="px-4 py-3">
        <LanguageSwitcher />
      </div>
      <a
        href={ctaHref}
        class="mt-3 flex items-center justify-center px-5 py-3 rounded-[var(--radius-xl)] text-base font-semibold transition-all duration-200"
        style="background: var(--color-secondary-container); color: var(--color-on-secondary-container);"
      >
        {ctaText}
      </a>
    </div>
  </div>
</header>

<!-- Spacer for fixed nav -->
<div class="h-20"></div>

<script>
  const nav = document.getElementById('main-nav')!;
  const scrollThreshold = 20;

  function updateNav() {
    if (window.scrollY > scrollThreshold) {
      nav.style.backgroundColor = 'rgba(250, 250, 245, 0.85)';
      nav.style.backdropFilter = 'blur(20px)';
      nav.style.webkitBackdropFilter = 'blur(20px)';
      nav.style.boxShadow = '0 1px 0 rgba(195, 198, 209, 0.15)';
    } else {
      nav.style.backgroundColor = 'transparent';
      nav.style.backdropFilter = 'none';
      nav.style.webkitBackdropFilter = 'none';
      nav.style.boxShadow = 'none';
    }
  }

  window.addEventListener('scroll', updateNav, { passive: true });
  updateNav();

  const toggle = document.getElementById('mobile-toggle')!;
  const menu = document.getElementById('mobile-menu')!;
  const iconMenu = document.getElementById('icon-menu')!;
  const iconClose = document.getElementById('icon-close')!;
  let isOpen = false;

  toggle.addEventListener('click', () => {
    isOpen = !isOpen;
    toggle.setAttribute('aria-expanded', String(isOpen));

    if (isOpen) {
      menu.style.maxHeight = menu.scrollHeight + 'px';
      menu.style.opacity = '1';
      iconMenu.classList.add('hidden');
      iconClose.classList.remove('hidden');
      nav.style.backgroundColor = 'rgba(250, 250, 245, 0.95)';
      nav.style.backdropFilter = 'blur(20px)';
      nav.style.webkitBackdropFilter = 'blur(20px)';
    } else {
      menu.style.maxHeight = '0';
      menu.style.opacity = '0';
      iconMenu.classList.remove('hidden');
      iconClose.classList.add('hidden');
      updateNav();
    }
  });
</script>
